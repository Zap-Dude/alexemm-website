---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog"
  description="Writing by Alexandros Emmanouilidis - on technology, networking, fencing, Orthodox faith, and everything else that deserves more than a note to himself."
>

  <section class="section">
    <div class="container--narrow">

      <span class="section-label">Blog</span>
      <h1>Writing</h1>
      <p class="blog-intro">
        When something is worth working out in writing, it ends up here. No
        schedule, no theme - just things that deserve more than a note to myself.
      </p>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p>No posts yet. Coming when there's something worth saying.</p>
        </div>
      ) : (
        <ul class="post-list" role="list">
          {posts.map(post => (
            <li class="post-item">
              <a href={`/blog/${post.slug}`} class="post-link">
                <div class="post-meta">
                  <time class="post-date" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  {post.data.tags?.length > 0 && (
                    <span class="post-tag">{post.data.tags[0]}</span>
                  )}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <span class="post-arrow">Read &rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

</BaseLayout>

<style>
  h1 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .blog-intro {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-2xl);
  }

  .empty-state {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-xl) var(--space-lg);
  }

  .empty-state p {
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition);
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-link:hover .post-arrow {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .post-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .post-title {
    font-size: 1.5rem;
    margin-bottom: var(--space-xs);
    transition: color var(--transition);
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    max-width: 58ch;
    margin-bottom: var(--space-xs);
  }

  .post-arrow {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }
</style>
