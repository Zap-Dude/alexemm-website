---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CV"
  description="CV of Alexandros Emmanouilidis — BSc Computer Science at UCY, GPA 8.10/10, CCNA 1 &amp; 2 certified, national fencing champion, and PwC intern, summer 2026."
>

  <section class="section">
    <div class="container--narrow">

      <div class="cv-header">
        <div>
          <span class="section-label">Curriculum vitae</span>
          <h1>Alexandros Emmanouilidis</h1>
          <p class="cv-meta">Nicosia, Cyprus &middot; alexemm1386@outlook.com</p>
        </div>
        <a href="/cv/alexandros-emmanouilidis-cv.pdf" class="btn btn--ghost cv-download" download>
          Download PDF
        </a>
      </div>

      <hr class="divider" />

      <!-- ===================== EXPERIENCE ===================== -->
      <section class="cv-section" aria-labelledby="experience-heading">
        <h2 id="experience-heading" class="cv-section-title">Experience</h2>

        <div class="cv-entry cv-entry--placeholder">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">[PLACEHOLDER: Role Title]</h3>
              <span class="cv-org">PwC</span>
            </div>
            <span class="cv-date">Summer 2026</span>
          </div>
          <p class="cv-note">To be completed after the internship ends.</p>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">National Fencing Referee (Épée)</h3>
              <span class="cv-org">Cyprus Fencing Federation</span>
            </div>
            <span class="cv-date">2024 – Present</span>
          </div>
          <ul class="cv-bullets">
            <li>Officiate national-level Épée matches, applying competition rules consistently under time pressure.</li>
            <li>Manage athlete conduct and resolve disputes calmly in high-stakes situations.</li>
            <li>Communicate decisions clearly and authoritatively to athletes, coaches, and spectators.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">Waiter / Runner</h3>
              <span class="cv-org">SML Hospitality</span>
            </div>
            <span class="cv-date">Sep 2023 – Mar 2024</span>
          </div>
          <ul class="cv-bullets">
            <li>Delivered table service in a high-volume environment, maintaining quality during peak periods.</li>
            <li>Coordinated food and drink running across sections with kitchen and floor teams.</li>
            <li>Handled customer requests and resolved issues on the spot.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">Store Assistant — Stock &amp; Customer Support</h3>
              <span class="cv-org">Tsiartas Supermarket</span>
            </div>
            <span class="cv-date">Jun 2022 – Aug 2022</span>
          </div>
          <ul class="cv-bullets">
            <li>Managed stock, restocking, and inventory organisation during summer peak period.</li>
            <li>Assisted customers on the shop floor with queries and day-to-day requests.</li>
          </ul>
        </div>
      </section>

      <hr class="divider" />

      <!-- ===================== EDUCATION ===================== -->
      <section class="cv-section" aria-labelledby="education-heading">
        <h2 id="education-heading" class="cv-section-title">Education</h2>

        <div class="cv-entry">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">BSc Computer Science</h3>
              <span class="cv-org">University of Cyprus (UCY)</span>
            </div>
            <span class="cv-date">2025 – 2029 (expected)</span>
          </div>
          <p class="cv-detail">GPA: 8.10 / 10</p>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-header">
            <div>
              <h3 class="cv-role">Cisco Certified Network Associate (CCNA)</h3>
              <span class="cv-org">Cisco</span>
            </div>
            <span class="cv-date">2024</span>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- ===================== SKILLS ===================== -->
      <section class="cv-section" aria-labelledby="skills-heading">
        <h2 id="skills-heading" class="cv-section-title">Skills</h2>

        <div class="skills-grid">
          <div class="skill-group">
            <h4 class="skill-group-title">Technical</h4>
            <ul class="skill-list">
              <li>Java (object-oriented programming)</li>
              <li>C++</li>
              <li>Networking fundamentals</li>
              <li>CCNA 1 &amp; 2</li>
              <li>Cyber/security awareness</li>
            </ul>
          </div>

          <div class="skill-group">
            <h4 class="skill-group-title">Languages</h4>
            <ul class="skill-list">
              <li>Greek — fluent</li>
              <li>English — fluent</li>
              <li>Russian — intermediate</li>
            </ul>
          </div>
        </div>
      </section>

    </div>
  </section>

</BaseLayout>

<style>
  /* Header */
  .cv-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  h1 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
    font-size: clamp(2rem, 4vw, 2.75rem);
  }

  .cv-meta {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .cv-download {
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  /* Section titles */
  .cv-section {
    margin-bottom: var(--space-sm);
  }

  .cv-section-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
  }

  /* Entries */
  .cv-entry {
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .cv-entry:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .cv-entry--placeholder {
    opacity: 0.6;
  }

  .cv-entry-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .cv-role {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .cv-org {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    display: block;
  }

  .cv-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cv-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cv-bullets li {
    font-size: 0.9375rem;
    color: var(--color-text);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.6;
  }

  .cv-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.8rem;
    top: 0.1em;
  }

  .cv-detail {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .cv-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .skill-group-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-list li {
    font-size: 0.9375rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .skill-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.8rem;
    top: 0.1em;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .cv-header {
      flex-direction: column;
    }

    .cv-entry-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
