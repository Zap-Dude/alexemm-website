---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Alexandros Emmanouilidis — via the contact form, email, Instagram, or Facebook. Open to conversations about work, writing, and fencing."
>

  <section class="section">
    <div class="container--narrow">

      <span class="section-label">Contact</span>
      <h1>Get in touch</h1>
      <p class="contact-intro">
        Whether it's about work, writing, fencing, or something else entirely — feel free
        to reach out.
      </p>

      <div class="contact-grid">

        <!-- Contact form -->
        <div class="form-wrap">
          <h2 class="contact-subhead">Send a message</h2>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
            action="/contact/success"
          >
            <!-- Netlify honeypot -->
            <input type="hidden" name="form-name" value="contact" />
            <p class="visually-hidden">
              <label>Don't fill this in: <input name="bot-field" /></label>
            </p>

            <div class="field">
              <label for="name" class="field-label">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="field-input"
                autocomplete="name"
                required
              />
            </div>

            <div class="field">
              <label for="email" class="field-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="field-input"
                autocomplete="email"
                required
              />
            </div>

            <div class="field">
              <label for="message" class="field-label">Message</label>
              <textarea
                id="message"
                name="message"
                class="field-input field-textarea"
                rows="6"
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn--primary submit-btn">Send message</button>
          </form>
        </div>

        <!-- Links -->
        <div class="links-wrap">
          <h2 class="contact-subhead">Elsewhere</h2>

          <ul class="contact-links" role="list">
            <li>
              <a href="mailto:alexemm1386@outlook.com" class="contact-link">
                <span class="link-icon" aria-hidden="true">✉</span>
                <span class="link-label">Email</span>
                <span class="link-value">alexemm1386@outlook.com</span>
              </a>
            </li>
            <li>
              <a
                href="https://instagram.com/alexandros_emmanouilides"
                class="contact-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="link-icon" aria-hidden="true">◎</span>
                <span class="link-label">Instagram</span>
                <span class="link-value">@alexandros_emmanouilides</span>
              </a>
            </li>
            <li>
              <a
                href="https://www.facebook.com/share/17GjSfEDzu/?mibextid=wwXIfr"
                class="contact-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="link-icon" aria-hidden="true">◈</span>
                <span class="link-label">Facebook</span>
                <span class="link-value">Alexandros Emmanouilidis</span>
              </a>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </section>

</BaseLayout>

<style>
  h1 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .contact-intro {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-bottom: var(--space-2xl);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-2xl);
    align-items: start;
  }

  .contact-subhead {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .field-input {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 4px;
    padding: 0.65rem 0.875rem;
    width: 100%;
    transition: border-color var(--transition);
    appearance: none;
  }

  .field-input:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .field-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.6;
  }

  .submit-btn {
    align-self: flex-start;
  }

  /* Contact links */
  .contact-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-link {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.75rem;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .contact-links li:first-child .contact-link {
    border-top: 1px solid var(--color-border);
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  .link-icon {
    grid-row: span 2;
    font-size: 1rem;
    color: var(--color-accent);
    padding-top: 0.15rem;
  }

  .link-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    display: block;
  }

  .link-value {
    font-size: 0.9375rem;
    display: block;
  }

  /* Accessibility */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Responsive */
  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
