---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <a href="/" class="footer-wordmark" aria-label="Alex Emmanouilidis - home">
      <span class="wordmark-alex">alex</span><span class="wordmark-emm">emm</span>
    </a>

    <nav class="footer-nav" aria-label="Footer navigation">
      <ul role="list">
        <li><a href="/about">About</a></li>
        <li><a href="/cv">CV</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/sport">Sport</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <p class="footer-copy">&copy; {year} Alexandros Emmanouilidis</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-xl);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-lg);
  }

  .footer-wordmark {
    font-family: var(--font-body);
    font-size: 1.125rem;
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .footer-wordmark:hover {
    color: var(--color-text);
  }

  .wordmark-alex { font-weight: 700; }
  .wordmark-emm  { font-weight: 300; }

  .footer-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md) var(--space-lg);
    list-style: none;
  }

  .footer-nav a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-md);
    }

    .footer-copy {
      white-space: normal;
    }
  }
</style>
